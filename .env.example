# Copy to `.env` in the repo root (that file is gitignored).
# Used by: `dashboard/app.py` (Streamlit) and `dbt/profiles.yml` (via env vars).

# --- Required for Snowflake (dashboard + dbt) ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=

# --- dbt defaults (optional; match your Snowflake setup) ---
# SNOWFLAKE_ROLE=ACCOUNTADMIN
# SNOWFLAKE_DBT_DATABASE=STAGING_DB
# SNOWFLAKE_DBT_SCHEMA=STG

# --- Dashboard-only overrides (optional; see app.py) ---
# SNOWFLAKE_WAREHOUSE=ANALYTICS_WH
# SNOWFLAKE_DATABASE=ANALYTICS_DB
# SNOWFLAKE_SCHEMA=MARTS

# --- Demo dashboard without Snowflake ---
# DASHBOARD_DEMO=1
